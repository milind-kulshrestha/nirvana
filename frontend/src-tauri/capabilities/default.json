{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "python-backend",
          "cmd": "python3",
          "args": [
            {
              "validator": ".*server\\.py$"
            }
          ],
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "python-backend",
          "cmd": "python3",
          "args": [
            {
              "validator": ".*server\\.py$"
            }
          ],
          "sidecar": false
        }
      ]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "process:allow-exit",
    "process:allow-restart"
  ]
}
