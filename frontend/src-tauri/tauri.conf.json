{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nirvana",
  "version": "0.1.0",
  "identifier": "app.nirvana.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Nirvana",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "scope": [
        {
          "name": "python-backend",
          "cmd": "python3",
          "args": [
            {
              "validator": ".*server\\.py$"
            }
          ],
          "sidecar": false
        }
      ]
    },
    "updater": {
      "pubkey": "PLACEHOLDER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/YOUR_OWNER/nirvana/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
